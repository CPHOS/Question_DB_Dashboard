# ── PostgreSQL ───────────────────────────────────────
POSTGRES_DB=qb
POSTGRES_USER=qb
POSTGRES_PASSWORD=change-this-password

# ── Backend (API) ───────────────────────────────────
QB_DATABASE_URL=postgres://qb:change-this-password@db:5432/qb
QB_JWT_SECRET=change-this-to-a-long-random-string
QB_API_PORT=8080
QB_MAX_DB_CONNECTIONS=20
QB_EXPORT_DIR=/var/lib/qb/exports
QB_CORS_ORIGINS=http://localhost
QB_API_IMAGE=qb_api
QB_API_TAG=latest

# ── Frontend (Web) ──────────────────────────────────
VITE_API_BASE=http://localhost:8080
QB_WEB_PORT=80
QB_WEB_IMAGE=qb_dashboard
QB_WEB_TAG=latest
